#!/bin/bash

if [ "$SKIP_VERSION_BUMP" = "1" ]; then
    echo "✓ Skipping version bump (SKIP_VERSION_BUMP flag set)"
    exit 0
fi

BRANCH=$(git rev-parse --abbrev-ref HEAD)
MERGED_BRANCH=$(git reflog -1 | grep -o "merge .*:" | cut -d' ' -f2 | cut -d':' -f1)

if [ "$BRANCH" != "master" ] || [ "$MERGED_BRANCH" != "develop" ]; then
    exit 0
fi

if [ ! -f "package.json" ]; then
    exit 0
fi

CHANGED_FILES=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD)
NON_MD_FILES=$(echo "$CHANGED_FILES" | grep -v '\.md$')

if [ -z "$NON_MD_FILES" ]; then
    echo "Only markdown files were changed. Skipping version bump."
    exit 0
fi

CURRENT_VERSION=$(node -p "require('./package.json').version")

if [ -z "$CURRENT_VERSION" ]; then
    echo "Error: could not read version from package.json"
    exit 1
fi

BUMP_TYPE="${VERSION_BUMP_TYPE:-minor}"

MAJOR=$(echo $CURRENT_VERSION | cut -d'.' -f1)
MINOR=$(echo $CURRENT_VERSION | cut -d'.' -f2)
PATCH=$(echo $CURRENT_VERSION | cut -d'.' -f3)

if [ "$BUMP_TYPE" = "patch" ]; then
    NEW_PATCH=$((PATCH + 1))
    NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"
else
    NEW_MINOR=$((MINOR + 1))
    NEW_VERSION="$MAJOR.$NEW_MINOR.0"
fi

bump_package_json() {
    local from="$1"
    local to="$2"
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "s/\"version\": \"$from\"/\"version\": \"$to\"/" package.json
    else
        sed -i "s/\"version\": \"$from\"/\"version\": \"$to\"/" package.json
    fi

    local actual=$(node -p "require('./package.json').version")
    if [ "$actual" != "$to" ]; then
        echo "Error: package.json version is '$actual', expected '$to'"
        return 1
    fi
}

bump_package_json "$CURRENT_VERSION" "$NEW_VERSION" || exit 1

git add package.json
SKIP_VERSION_BUMP=1 git commit -m "chore: bump version to $NEW_VERSION" || exit 1

PREVIOUS_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "")

if [ -n "$PREVIOUS_TAG" ]; then
    CHANGELOG=$(git log $PREVIOUS_TAG..HEAD --pretty=format:"- %s (%h)" --no-merges)
else
    CHANGELOG=$(git log --pretty=format:"- %s (%h)" --no-merges)
fi

TAG_MESSAGE="Release version $NEW_VERSION

Changelog:
$CHANGELOG"

git tag -a "v$NEW_VERSION" -m "$TAG_MESSAGE"

echo "Version bumped from $CURRENT_VERSION to $NEW_VERSION"
echo "Tag v$NEW_VERSION created with changelog:"
echo "$CHANGELOG"

echo "Syncing version to develop branch..."
git checkout develop || exit 1

DEVELOP_VERSION=$(node -p "require('./package.json').version")
if [ "$DEVELOP_VERSION" != "$NEW_VERSION" ]; then
    bump_package_json "$DEVELOP_VERSION" "$NEW_VERSION" || { git checkout master; exit 1; }
    git add package.json
    SKIP_VERSION_BUMP=1 git commit -m "chore: sync version to $NEW_VERSION from master" || { git checkout master; exit 1; }
    echo "Version synced to develop branch"
else
    echo "Develop already at $NEW_VERSION, no sync needed"
fi

echo ""
echo "   IMPORTANT: Remember to push both branches and tags:"
echo "   git push origin master"
echo "   git push origin develop"
echo "   git push origin v$NEW_VERSION"
echo ""

git checkout master
